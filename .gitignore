# --- Secrets & local env (never commit real keys) ---
.env
.env.local
.env.*.local
*.pem
*.key

# Keep templates and non-secret workspace overlays
!.env.example
!.env.gb39901
!.env.gb39901_v3
!.env.gb39901_v4

# --- Runtime / heavy artifacts ---
# Root-only leading slash so benchmark/results is not swallowed.
# Ship only the final v4 vector/KV workspace; rebuild Neo4j locally.
/data/*
!/data/rag_storage/
/data/rag_storage/*
!/data/rag_storage/aeb_gb39901_v4_relation_guard/
!/data/rag_storage/aeb_gb39901_v4_relation_guard/**
# Regenerable LLM call cache — skip noise / bloat
/data/rag_storage/aeb_gb39901_v4_relation_guard/kv_store_llm_response_cache.json
/results/
# Local ingest reports stay private; ship only the final v4 embedding fingerprint.
/state/*
!/state/embedding_fingerprint.aeb_gb39901_v4_relation_guard.json
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
.venv/
venv/
*.egg-info/
.DS_Store
**/.DS_Store

# --- Corpus ---
# Track prepared + index-ready units for rebuild demos.
# Keep raw OCR/PDF dumps local only (size + redistribution caution).
corpus/raw/*
!corpus/raw/.gitkeep

# --- Benchmark: keep gold data + small human reports; drop bulky run dumps ---
!benchmark/data/
!benchmark/data/**
benchmark/results/**
!benchmark/results/.gitkeep
!benchmark/results/benchmark_report.md
!benchmark/results/pilot_6q_report.md
!benchmark/results/benchmark_smoke_report.md

# Local review exports / generated inspect dumps
benchmark/review/**
!benchmark/review/.gitkeep

# --- Logs & traces ---
*.log
**/trace*.json

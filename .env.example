# Docker images are deliberately pinned to stable release lines.
# Default path: pull official LightRAG and bind-mount ./lightrag_custom (see compose.yaml).
LIGHTRAG_IMAGE=ghcr.io/hkuds/lightrag:v1.4.16
NEO4J_IMAGE=neo4j:5.26
# Optional thin app image (make lightrag-image / make v4-up-app). No secrets or index data.
# LIGHTRAG_BASE_IMAGE=ghcr.io/hkuds/lightrag:v1.4.16
# LIGHTRAG_APP_IMAGE=evidencetrail-lightrag:v1.4.16-app

# Local-only Neo4j credentials. Change this before running the demo.
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_with_a_local_password
NEO4J_DATABASE=neo4j

# OpenAI-compatible chat endpoint.
LLM_BINDING=openai
LLM_BINDING_HOST=https://your-openai-compatible-host.example/v1
LLM_BINDING_API_KEY=replace_with_your_chat_api_key
LLM_MODEL=replace_with_a_non_reasoning_chat_model

# OpenAI-compatible embedding endpoint. It may be the same provider as chat.
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://your-openai-compatible-host.example/v1
EMBEDDING_BINDING_API_KEY=replace_with_your_embedding_api_key
EMBEDDING_MODEL=replace_with_a_multilingual_embedding_model
EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_USE_BASE64=false

# Demo configuration.
WORKSPACE=aeb_demo
SUMMARY_LANGUAGE=English
ENTITY_TYPES=["Regulation","Protocol","Version","Region","VehicleCategory","System","TestScenario","TestTarget","Requirement","Condition","Parameter","Metric","Threshold","Actor"]
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100
MAX_ASYNC=4
MAX_PARALLEL_INSERT=1
RERANK_BINDING=null
WEBUI_TITLE=Passenger Vehicle AEB GraphRAG Demo
WEBUI_DESCRIPTION=UNECE and Euro NCAP active-safety knowledge graph

# Internal URLs used by the helper container. Usually no change is needed.
LIGHTRAG_API_URL=http://lightrag:9621
NEO4J_HTTP_URL=http://neo4j:7474

